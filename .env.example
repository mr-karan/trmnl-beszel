# Beszel hub (PocketBase) — the web URL, not the agent socket
BESZEL_URL=https://beszel.example.com
BESZEL_EMAIL=you@example.com
BESZEL_PASSWORD=changeme

# TRMNL Private Plugin webhook URL (full URL incl. UUID)
# Find it on https://usetrmnl.com/plugin_settings?keyname=private_plugin
# after creating a plugin with strategy = Webhook
TRMNL_WEBHOOK_URL=https://trmnl.com/api/custom_plugins/REPLACE-WITH-UUID

# Timezone for the timestamp shown on the card
TZ=Asia/Kolkata
